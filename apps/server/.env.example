DATABASE_URL=postgresql://cueball:cueball@localhost:5432/cueball
REDIS_URL=redis://localhost:6379
PORT=4000
JWT_SECRET=dev-secret-change-me
CLIENT_ORIGIN=http://localhost:3000

# Google Cloud OAuth client (YouTube Data API v3) — see README for setup steps.
# Leave unset to run without YouTube playlist sync; the connect button just
# returns a 503 instead of crashing the server.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/youtube/callback
