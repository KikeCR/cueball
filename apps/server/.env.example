DATABASE_URL=postgresql://cueball:cueball@localhost:5432/cueball
REDIS_URL=redis://localhost:6379
PORT=4000
JWT_SECRET=dev-secret-change-me
CLIENT_ORIGIN=http://localhost:3000

# Google Cloud OAuth client, shared by two separate flows, see README for
# setup steps. Leave unset to run without either: the YouTube connect button
# returns a 503, and the "Continue with Google" button redirects back with
# an error instead of crashing the server.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# YouTube Data API v3 access (per room, to sync a real playlist).
GOOGLE_REDIRECT_URI=http://localhost:4000/api/youtube/callback
# Account sign-in/register identity only (no API access requested).
GOOGLE_AUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# Rooms with zero connected participants and no activity for this many hours
# are deleted automatically (cascades to participants/queue/votes). Their
# YouTube playlist, if any, is left alone on the host's account.
ROOM_EXPIRY_HOURS=24
# How often the expiry sweep runs.
ROOM_SWEEP_INTERVAL_MINUTES=30
